{
  "name": "hookforms-cloud",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Webhook inbox with Gmail forwarding — runs entirely on Cloudflare Workers",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply hookforms-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply hookforms-db --local",
    "gmail:upload": "node scripts/upload-gmail-token.mjs"
  },
  "dependencies": {
    "hono": "^4.11.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.50.0"
  }
}
